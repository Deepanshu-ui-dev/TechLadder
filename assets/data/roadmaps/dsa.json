      "title": "Programming Fundamentals",
      "nodes": [
        {
          "id": "n-lang-syntax",
          "title": "Language Syntax",
          "description": "Pick one language — Java, C++, Python, or JavaScript. Master variables, data types, operators, and basic I/O.",
