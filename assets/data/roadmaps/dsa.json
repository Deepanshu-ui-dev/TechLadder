            { "type": "course", "title": "JavaScript Tutorial", "url": "https://www.w3schools.com/js/", "source": "W3Schools" }
          ],
          "prerequisites": [],
          "nextNodes": ["n-control", "n-functions"]
        },
        {
          "id": "n-control",
          "title": "Control Structures & Loops",
          "description": "Loops (for, while), conditionals (if-else, switch), and control flow.",
